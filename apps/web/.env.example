# === API Provider Keys ===
MISTRAL_API_KEY=
MISTRAL_API_KEY_2=         # fallback key
MISTRAL_API_KEY_3=         # fallback key

# === App Configuration ===
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/chat
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/chat
NEXT_PUBLIC_APP_URL=https://your-app.netlify.app

# === Analytics ===
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# === Netlify Deployment Notes ===
#
# Set these env vars in the Netlify Dashboard → Site settings → Environment variables:
#
# Required for build:
#   NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY
#   CLERK_SECRET_KEY
#   MISTRAL_API_KEY          (and MISTRAL_API_KEY_2/3 if using)
#   NEXT_PUBLIC_APP_URL      (your Netlify URL, e.g. https://flux-ai.netlify.app)
#
# Optional:
#   FREE_CREDITS_LIMIT_REQUESTS_AUTH = "0"
#   FREE_CREDITS_LIMIT_REQUESTS_IP = "20"
#   KV_REST_API_URL          (Upstash Redis URL for credit tracking)
#   KV_REST_API_TOKEN        (Upstash Redis token)
#   NEXT_PUBLIC_POSTHOG_KEY  (analytics)
#   NEXT_PUBLIC_POSTHOG_HOST (analytics host)
#
# Note: @vercel/kv works on any platform as long as KV_REST_API_URL and
# KV_REST_API_TOKEN are set (it connects directly to Upstash Redis).
